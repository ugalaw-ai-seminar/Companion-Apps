const charSkills=[[],[],[]];
function toggleSkill(ci,key,el){
  const arr=charSkills[ci];
  const idx=arr.indexOf(key);
  if(idx>-1){
    arr.splice(idx,1);
    el.classList.remove('active');
  } else if(arr.length<2){
    arr.push(key);
    el.classList.add('active');
  }
  document.getElementById('sl_'+ci).textContent=`${arr.length} / 2 selected`;
}

