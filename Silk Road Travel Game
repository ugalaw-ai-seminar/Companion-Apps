// ═══════ SKILL HELPERS ═══════
function partyHasSkill(skill){return S.skills.some((arr,i)=>S.alive[i]&&arr.includes(skill))}
function getAllPartySkills(){const all=new Set();S.skills.forEach((arr,i)=>{if(S.alive[i])arr.forEach(s=>all.add(s))});return all}

// ═══════ PICK EVENT (ensures variety, no repeats per playthrough) ═══════
// With 58 unique events and only 24 needed per playthrough (8 legs × 3 events),
// we guarantee zero repeats in any single game!
function pickEv(){
  // Get events not yet used
  const available=EVS.filter(e=>!S.used.has(e.id));
  
  // If we've exhausted all events (highly unlikely with 58 events and 3 per leg × 8 legs = 24 total)
  if(available.length===0){
    S.used.clear();
    return EVS[Math.floor(Math.random()*EVS.length)];
  }

  // Track what types we've seen in the last few events to avoid clustering
  if(!S.recentTypes)S.recentTypes=[];
  
  // Prefer events whose type we haven't seen in the last 3 events
  const diverse=available.filter(e=>!S.recentTypes.includes(e.type));
  const pool=diverse.length>0?diverse:available;
  
  // Pick randomly from the diverse pool
  const ev=pool[Math.floor(Math.random()*pool.length)];
  
  // Mark as used (no repeats for entire playthrough)
  S.used.add(ev.id);
  
  // Track recent types (keep last 3)
  S.recentTypes.push(ev.type);
  if(S.recentTypes.length>3)S.recentTypes.shift();
  
  return ev;
}

// ═══════ SHOW EVENT ═══════
function showEv(){
  if(S.evDone>0&&S.evDone%S.evPerLeg===0){
    S.wpIdx++;
    if(S.wpIdx>=WP.length-1){winGame();return}
    updTrack();
    addLog(`⚑ Arrived at ${WP[S.wpIdx].name}`,true);
    S.f=Math.max(0,S.f-10);
    updateHUD();
    if(checkDeath())return;
  }

  const ev=pickEv();S.curEv=ev;
  const partySkills=getAllPartySkills();

  animateStage(ev.type,ev.icon,ev.type);

  const tagEl=$('ev-tag');tagEl.className='ev-tag '+ev.tag;
  tagEl.textContent=ev.type.charAt(0).toUpperCase()+ev.type.slice(1);
  setT('ev-title',ev.title);
  setT('ev-text',ev.text);

  const sbDiv=$('skill-bonus-display');sbDiv.innerHTML='';
  if(ev.skillBonus){
    Object.entries(ev.skillBonus).forEach(([sk,hint])=>{
      if(partySkills.has(sk)){
        sbDiv.innerHTML+=`<div class="skill-bonus">${SKILLS[sk].icon} <strong>${SKILLS[sk].name}:</strong> ${hint}</div>`;
      }
    });
  }

  const nc=$('narrative-card');nc.classList.remove('fade-in');void nc.offsetWidth;nc.classList.add('fade-in');

  const cc=$('choices-con');cc.innerHTML='';
  const L=['I','II','III'];
  ev.ch.forEach((ch,i)=>{
    const hasBenefit=ch.b&&ch.b.some(s=>partySkills.has(s));
    const b=document.createElement('button');b.className='ch-btn'+(hasBenefit?' boosted':'');
    const boostLine=hasBenefit?`<div class="ch-boost">${ch.b.filter(s=>partySkills.has(s)).map(s=>`${SKILLS[s].icon} ${SKILLS[s].name} skill active`).join(' · ')}</div>`:'';
    b.innerHTML=`<span class="ch-letter">${L[i]}</span><div><div>${ch.t}</div><div class="ch-cost">${ch.c}</div>${boostLine}</div>`;
    b.onclick=()=>resolve(ev,ch,i);
    cc.appendChild(b);
  });

  $('outcome-sec').style.display='none';
  hide('cont-sec');show('choices-sec');
}

// ═══════ RESOLVE CHOICE ═══════
function resolve(ev,ch,ci){
  const partySkills=getAllPartySkills();
  const hasBenefit=ch.b&&ch.b.some(s=>partySkills.has(s));
  let oKey=ch.o;

  if(hasBenefit){
    const activeSkills=ch.b.filter(s=>partySkills.has(s));
    for(const sk of activeSkills){
      // Try various boost key patterns
      const tries=[
        ch.o+'_'+sk.charAt(0),        // bf_w
        ch.o+'_'+sk.substring(0,3),   // bf_war
        ch.o+'_boost',                 // bf_boost
        ch.o+'_'+sk,                   // bf_warrior
      ];
      for(const k of tries){if(OTS[k]){oKey=k;break}}
      if(oKey!==ch.o)break;
    }
  }

  // Special risk variants
  if(ch.o==='m2gems'&&!partyHasSkill('trader')&&!partyHasSkill('scholar')&&Math.random()<.5) oKey='m2gems_risk';
  if(ch.o==='d3salvage'&&!partyHasSkill('healer')) oKey='d3salvage_risk';
  if(ch.o==='p5negotiate'&&!partyHasSkill('diplomat')) oKey='p5negotiate_risk';
  if(ch.o==='w8race'&&partyHasSkill('navigator')) oKey='w8race_n';
  if(ch.o==='wg'&&partyHasSkill('navigator')) oKey='wg_n';
  if(ch.o==='w3cross'&&partyHasSkill('engineer')) oKey='w3cross_e';

  const out=OTS[oKey]||OTS[ch.o];
  if(!out){console.warn('Missing outcome:',oKey,'falling back to base');return}

  out.fn(S);
  S.evDone++;
  S.day+=Math.floor(Math.random()*3)+2;
  updateHUD();

  hide('choices-sec');
  $('outcome-sec').style.display='block';
  const card=$('out-card');
  const isBad=out.efx.some(e=>!e.g);
  const isGood=out.efx.every(e=>e.g);
  card.className='panel '+(isBad?'out-bad':isGood?'out-good':'out-neutral');
  setT('out-text',out.txt);

  const efDiv=$('out-efx');efDiv.innerHTML='';
  (out.efx||[]).forEach(ef=>{
    const s=document.createElement('span');
    s.className='eff '+(ef.g?'eff-good':'eff-bad');s.textContent=ef.l;efDiv.appendChild(s);
  });

  if(isBad){['sb-m','sb-f','sb-g','sb-c'].forEach(id=>{const e=$(id);if(e){e.classList.add('pulse-bad');setTimeout(()=>e.classList.remove('pulse-bad'),700)}})}
  else if(isGood){['sb-g','sb-c'].forEach(id=>{const e=$(id);if(e){e.classList.add('pulse-good');setTimeout(()=>e.classList.remove('pulse-good'),700)}})}

  addLog(`Day ${S.day}: ${ev.title} → Choice ${['I','II','III'][ci]}`+(hasBenefit?' ✦':''),false);
  if(checkDeath())return;
  show('cont-sec');
}

function nextEvent(){hide('cont-sec');showEv()}

// ═══════ DEATH CHECK ═══════
function checkDeath(){
  if(S.m<=0){gameOver('All your merchants have perished. The caravan was lost to the sands of time.');return true}
  if(S.f<=0){gameOver('Your provisions ran out. The caravan starved in the unforgiving desert.');return true}
  if(S.g<=0&&S.c<=0){gameOver('Bankrupt and stripped of all goods, your caravan could not continue.');return true}
  return false;
}

// ═══════ GAME OVER ═══════
function gameOver(reason){
  hide('screen-game');
  const go=$('screen-go');go.style.display='block';go.classList.add('screen');
  setT('go-reason',reason);
  setT('go-score',WP[S.wpIdx].km.toLocaleString());
}

// ═══════ WIN & SCORE (cargo-based, detailed) ═══════
function winGame(){
  hide('screen-game');
  const win=$('screen-win');win.style.display='block';win.classList.add('screen');

  const alive=S.names.filter((_,i)=>S.alive[i]);
  setT('win-txt',`${alive.join(', ')} — your caravan has crossed the ancient world from Chang'an to Rome. The Senate shall hear of this triumph!`);

  // ── SCORING BREAKDOWN ──
  // Cargo is the primary score driver (represents what you brought home)
  const cargoPct = Math.min(100, Math.round((S.c / S.startCargo) * 100));
  const cargoRetained = S.c;
  const cargoScore = cargoRetained * 5;    // 5 pts per unit of cargo
  const goldScore = S.g;                   // 1 pt per denarius
  const merchantBonus = S.m * 60;         // 60 pts per surviving merchant
  const skillCount = S.skills.flat().filter(Boolean).length;
  const skillBonus = skillCount * 15;      // 15 pts per skill used
  const peakBonus = Math.max(0, S.peakCargo - S.startCargo) * 3; // bonus for growing cargo

  const total = cargoScore + goldScore + merchantBonus + skillBonus + peakBonus;

  let rating,rClass,rDesc;
  if(total>=650){rating='LEGENDARY';rClass='rating-legendary';rDesc='A triumph for the ages. Rome has not seen such riches since the days of Caesar himself.'}
  else if(total>=480){rating='HEROIC';rClass='rating-heroic';rDesc='A remarkable achievement. Poets and historians will record this journey for centuries.'}
  else if(total>=320){rating='MERCHANT';rClass='rating-merchant';rDesc='A solid profit. The Senate is pleased and the trading houses are impressed.'}
  else if(total>=170){rating='TRAVELER';rClass='rating-traveler';rDesc='You made it — bruised, lean, and considerably wiser for the experience.'}
  else{rating='SURVIVOR';rClass='rating-survivor';rDesc='Barely alive, barely profitable. But you stand in Rome, and that is more than most can say.'}

  const badge=$('win-rating-badge');
  badge.className='rating-badge '+rClass;
  badge.textContent=rating;
  setT('win-score',total.toLocaleString());

  // Score breakdown
  const breakdown=$('score-breakdown');
  breakdown.innerHTML=`
    <div class="sb-row"><div class="sb-cat">Cargo Brought Home</div><div class="sb-val">${cargoScore}</div></div>
    <div class="sb-row"><div class="sb-cat">Remaining Denarii</div><div class="sb-val">${goldScore}</div></div>
    <div class="sb-row"><div class="sb-cat">Survivors (×60)</div><div class="sb-val">${merchantBonus}</div></div>
    <div class="sb-row"><div class="sb-cat">Skills Used (×15)</div><div class="sb-val">${skillBonus}</div></div>
    ${peakBonus>0?`<div class="sb-row"><div class="sb-cat">Trade Growth Bonus</div><div class="sb-val">${peakBonus}</div></div>`:''}
    <div class="sb-row full"><div class="sb-cat">Cargo Retention Rate</div><div class="sb-val" style="color:${cargoPct>=80?'#80c878':cargoPct>=50?'var(--gold)':'#e57373'}">${cargoPct}% of original</div></div>
  `;

  // Cargo Manifest
  buildCargoManifest(cargoRetained);
}

function buildCargoManifest(totalCargo){
  const container=$('cargo-manifest');
  if(!container||totalCargo<=0){if(container)container.style.display='none';return}
  container.style.display='block';
  container.innerHTML=`<div class="cargo-title">📦 &nbsp;Cargo Manifest — What You Brought to Rome</div>`;

  // Distribute cargo across categories based on total
  const types=Object.entries(CARGO_TYPES);
  const portions=[];
  let remaining=totalCargo;

  // Allocate based on weighted values
  types.forEach(([key,ct],i)=>{
    const isLast=i===types.length-1;
    const share=isLast?remaining:Math.max(0,Math.round((Math.random()*0.3+0.05)*totalCargo));
    const actual=Math.min(share,remaining);
    remaining-=actual;
    if(actual>0)portions.push({key,ct,amount:actual});
  });

  // Sort by value descending
  portions.sort((a,b)=>b.ct.value-a.ct.value);

  portions.forEach(({ct,amount})=>{
    const romValue=amount*ct.value;
    const barPct=Math.min(100,Math.round((amount/totalCargo)*100));
    container.innerHTML+=`
      <div class="cargo-item">
        <div class="cargo-item-icon">${ct.icon}</div>
        <div class="cargo-item-info">
          <div class="cargo-item-name">${ct.name}</div>
          <div class="cargo-item-val">${amount} units · ${romValue} denarii in Rome</div>
          <div class="cargo-bar"><div class="cargo-bar-fill" style="width:${barPct}%"></div></div>
        </div>
      </div>`;
  });
}

// ═══════ LOG ═══════
function addLog(text,milestone=false){
  const body=$('log-body');
  const el=document.createElement('div');
  el.className='log-e'+(milestone?' milestone':'');
  el.innerHTML=`<span class="log-day">${milestone?'⚑ ':''} Day ${S.day}</span> — ${text}`;
  body.insertBefore(el,body.firstChild);
}
function toggleLog(){
  const b=$('log-body'),a=$('log-arr');
  if(b.style.display==='block'){b.style.display='none';a.textContent='▼'}
  else{b.style.display='block';a.textContent='▲'}
}
</script>
