// ═══════ WAYPOINT TRACK ═══════
function buildTrack(){
  const t=$('prog-track');t.innerHTML='';
  WP.forEach((wp,i)=>{
    if(i>0){const l=document.createElement('div');l.className='wp-line';l.id='wl'+i;t.appendChild(l)}
    const w=document.createElement('div');w.className='wp';
    w.innerHTML=`<div class="wp-dot${i===0?' done':''}" id="wd${i}">${wp.icon}</div><div class="wp-name">${wp.name}</div>`;
    t.appendChild(w);
  });
  updTrack();
}
function updTrack(){
  WP.forEach((_,i)=>{
    const d=$('wd'+i),l=$('wl'+i);
    if(!d)return;
    d.className='wp-dot';
    if(i<S.wpIdx){d.classList.add('done');if(l)l.classList.add('done')}
    else if(i===S.wpIdx)d.classList.add('cur');
    if(l&&i<=S.wpIdx)l.classList.add('done');
  });
  // Update region badge
  const rb=$('region-badge');
  if(rb&&WP[S.wpIdx])rb.textContent=WP[S.wpIdx].region;
}

