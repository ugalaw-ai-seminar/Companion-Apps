  pn:{txt:'You negotiated the tax down substantially. The official accepted a smaller sum with good grace.',efx:[{l:'Negotiated',g:1},{l:'−20 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-20)}},
  pn_t:{txt:'Your trader reduced the bribe to a token amount. The official was charmed by the negotiation itself.',efx:[{l:'Trader bonus!',g:1},{l:'−8 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-8)}},
  pa:{txt:'The Sogdian alliance brought strength in numbers. Extra guards and provisions joined your caravan.',efx:[{l:'+20 cargo value',g:1},{l:'+12 provisions',g:1}],fn:G=>{G.c+=20;G.f+=12}},
  pd2:{txt:'Your combined negotiation skills landed a deal: shared guards, shared provisions, and a cash bonus.',efx:[{l:'Skill bonus!',g:1},{l:'+15 denarii',g:1}],fn:G=>{G.g+=15;G.f+=8}},
  pd:{txt:'You declined the alliance. A week later you heard the Sogdian caravan was robbed. Perhaps wise.',efx:[{l:'Stayed independent',g:1},{l:'No change',g:1}],fn:G=>{}},
  kf:{txt:'The feast was magnificent. The Khan was so delighted by your gifts he provided guards for the next leg.',efx:[{l:'Khan\'s favour',g:1},{l:'−8 cargo, +protection',g:1}],fn:G=>{G.c=Math.max(0,G.c-8)}},
  kf_d:{txt:'Your diplomat navigated court beautifully. The Khan not only accepted the gifts — he sent you with his personal escort.',efx:[{l:'Diplomat bonus!',g:1},{l:'−8 cargo, free escort',g:1}],fn:G=>{G.c=Math.max(0,G.c-8);G.g+=15}},
  ke:{txt:'You attended empty-handed. The Khan was offended. He sent you away, but without causing harm.',efx:[{l:'Offended Khan',g:0},{l:'No direct harm',g:0}],fn:G=>{if(Math.random()<.25&&G.m>1)G.m--}},
  kv:{txt:'Your merchant envoy charmed the Khan\'s court. He returned with an invitation to trade at palace prices.',efx:[{l:'Diplomatic trade',g:1},{l:'+20 denarii',g:1}],fn:G=>{G.g+=20}},
  p4docs:{txt:'Your Senate documentation was in order. The official apologised and waved you through.',efx:[{l:'Documentation valid',g:1},{l:'No cost',g:1}],fn:G=>{}},
  p4docs_d:{txt:'Your diplomat cited not only the documents but three historical precedents. The official bowed deeply.',efx:[{l:'Diplomat bonus!',g:1},{l:'No cost, +respect',g:1}],fn:G=>{G.g+=8}},
  p4docs_s:{txt:'Your scholar identified the exact treaty clause that applied. The official had no legal leg to stand on.',efx:[{l:'Scholar bonus!',g:1},{l:'Free passage',g:1}],fn:G=>{G.g+=5}},
  p4bribe:{txt:'The bribe worked efficiently. The official pocketed the coin without meeting your eyes.',efx:[{l:'Bribed',g:1},{l:'−25 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-25)}},
  p4bribe_t:{txt:'Your trader made the bribe look like a gift. The official ended up feeling flattered.',efx:[{l:'Trader bonus!',g:1},{l:'−12 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-12)}},
  p4contest:{txt:'The public challenge worked. A senior magistrate overheard and intervened on your behalf.',efx:[{l:'Public vindication',g:1},{l:'+5 denarii reward',g:1}],fn:G=>{G.g+=5;if(Math.random()<.25&&G.m>1)G.m--}},
  p5negotiate:{txt:'Your diplomat managed to get written safe-passage agreements from both warring parties. A masterpiece.',efx:[{l:'Safe passage!',g:1},{l:'−12 denarii cost',g:0}],fn:G=>{G.g=Math.max(0,G.g-12)}},
  p5negotiate_risk:{txt:'The negotiations broke down mid-road. You ran through the battle lines losing cargo in the chaos.',efx:[{l:'Made it through',g:1},{l:'−20 cargo',g:0}],fn:G=>{G.c=Math.max(0,G.c-20)}},
  p5mountains:{txt:'The mountain route was brutal but peaceful. You arrived late but unharassed.',efx:[{l:'Safe detour',g:1},{l:'−22 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-22)}},
  p5mountains_n:{txt:'Your navigator found a shortcut through the mountains that halved the time.',efx:[{l:'Navigator bonus!',g:1},{l:'−12 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-12)}},
  p5tribute:{txt:'You paid tribute to the dominant faction. They gave you a sealed letter of passage that worked perfectly.',efx:[{l:'Tribute paid',g:1},{l:'−30 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-30)}},
  p6buy:{txt:'The forged documents worked at three checkpoints. At the fourth, a sharp-eyed official looked twice — but let you through.',efx:[{l:'Documents worked',g:1},{l:'−15 denarii, risky',g:0}],fn:G=>{G.g=Math.max(0,G.g-15);if(Math.random()<.3)G.c=Math.max(0,G.c-15)}},
  p6check:{txt:'Your scholar spotted two errors in the documents. Good thing — the next checkpoint was especially thorough.',efx:[{l:'Scholar bonus!',g:1},{l:'Avoided disaster',g:1}],fn:G=>{}},
  p6report:{txt:'You reported the forger to the local magistrate. He rewarded you with a letter of safe passage worth far more.',efx:[{l:'Diplomat bonus!',g:1},{l:'+10 denarii + safe passage',g:1}],fn:G=>{G.g+=10}},
  p7siege:{txt:'The besieging army\'s camp market was surprisingly well-stocked. You resupplied cheaply while armies clashed in the distance.',efx:[{l:'Resupplied',g:1},{l:'−10 denarii, +12 provisions',g:1}],fn:G=>{G.g=Math.max(0,G.g-10);G.f+=12}},
  p7wait:{txt:'You waited outside the walls for four days. The siege ended and you rode in as liberators.',efx:[{l:'Wait resolved',g:1},{l:'−20 provisions, +goodwill',g:0}],fn:G=>{G.f=Math.max(0,G.f-20)}},
  p7sneak:{txt:'Crossing the siege lines in darkness was nightmarish but your scout and engineer found a way through.',efx:[{l:'Skill bonus!',g:1},{l:'No losses',g:1}],fn:G=>{}},
  p8invoke:{txt:'Your diplomat cited the relevant Han imperial law. The general checked with his scribe and found it was indeed valid.',efx:[{l:'Skill bonus!',g:1},{l:'Guards retained',g:1}],fn:G=>{}},
  p8donate:{txt:'A generous donation to the general\'s campaign fund. He released your guards and gave you a military escort.',efx:[{l:'Negotiated',g:1},{l:'−35 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-35);G.f+=10}},
  p8comply:{txt:'You complied. Without guards, the caravan was vulnerable — but you made it through with only minor losses.',efx:[{l:'Complied',g:0},{l:'−15 cargo (unprotected)',g:0}],fn:G=>{G.c=Math.max(0,G.c-15)}},
  // ── Travel ──
  tn:{txt:'The northern route was contested, but you passed through in tense silence. No attack came.',efx:[{l:'Passed safely',g:1},{l:'Luck held',g:0}],fn:G=>{if(Math.random()<.3){G.c=Math.max(0,G.c-10)}}},
  tn_s:{txt:'Your scout scouted ahead and found the road completely clear. The northern route saved two days.',efx:[{l:'Scout bonus!',g:1},{l:'+time saved',g:1}],fn:G=>{G.g+=8}},
  ts:{txt:'The southern road was peaceful and fertile. Local farmers sold you provisions at fair prices.',efx:[{l:'Peaceful journey',g:1},{l:'−10 provisions, +goodwill',g:0}],fn:G=>{G.f=Math.max(0,G.f-10+8)}},
  ts_n:{txt:'Your navigator knew exactly where the fertile farms were. You resupplied and saved five days.',efx:[{l:'Navigator bonus!',g:1},{l:'Efficient route',g:1}],fn:G=>{G.f+=10}},
  ta:{txt:'The shepherd\'s advice was sound. He pointed you to a hidden road that avoided the worst of both routes.',efx:[{l:'Local knowledge',g:1},{l:'−5 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-5);G.f+=5}},
  tc:{txt:'Two magnificent Bactrian camels joined your caravan. Your cargo capacity increased substantially.',efx:[{l:'+20 cargo capacity',g:1},{l:'−40 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-40);G.c+=20}},
  tc_t:{txt:'Your trader haggled masterfully. The camels cost half price and came with a month\'s feed.',efx:[{l:'Trader bonus!',g:1},{l:'−20 denarii, +20 cargo, +provisions',g:1}],fn:G=>{G.g=Math.max(0,G.g-20);G.c+=20;G.f+=10}},
  tsc:{txt:'You traded excess cargo for coin. The caravan moved lighter and faster.',efx:[{l:'Lightened load',g:1},{l:'−15 cargo, +20 denarii',g:0}],fn:G=>{G.c=Math.max(0,G.c-15);G.g+=20}},
  tsc_t:{txt:'Your trader got exceptional prices. A minor cargo reduction turned into a major profit.',efx:[{l:'Trader bonus!',g:1},{l:'−10 cargo, +30 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-10);G.g+=30}},
  tp:{txt:'You moved on without stopping. Three days later you wished you had bought those camels.',efx:[{l:'Kept moving',g:1},{l:'No change',g:0}],fn:G=>{}},
  t3high:{txt:'The high pass was brutal but exhilarating. Three days of freezing altitude, but the views were eternal.',efx:[{l:'Crossed!',g:1},{l:'−8 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-8);if(Math.random()<.3&&G.m>1)G.m--}},
  t3high_boost:{txt:'Your navigator and scout worked in perfect tandem. The pass was crossed without a single casualty.',efx:[{l:'Skill bonus!',g:1},{l:'Safely crossed',g:1}],fn:G=>{}},
  t3low:{txt:'The low swamp route was miserable — muddy, slow, and disease-prone. But you made it through.',efx:[{l:'Through the swamp',g:1},{l:'−18 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-18);if(Math.random()<.2&&G.m>1)G.m--}},
  t3guide:{txt:'The mountain guide knew every hidden path. You crossed in half the normal time.',efx:[{l:'Guide hired',g:1},{l:'−22 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-22);G.f+=5}},
  t4slow:{txt:'The careful crossing worked. Each wagon made it across, though the last one scraped the sides.',efx:[{l:'Crossed safely',g:1},{l:'Minor damage',g:0}],fn:G=>{if(Math.random()<.2)G.c=Math.max(0,G.c-8)}},
  t4slow_w:{txt:'Your warrior organised the crossing with military precision. Every wagon cleared the bridge cleanly.',efx:[{l:'Warrior bonus!',g:1},{l:'No damage',g:1}],fn:G=>{}},
  t4carry:{txt:'Carrying everything by hand was exhausting. It took two days but everything crossed intact.',efx:[{l:'All cargo safe',g:1},{l:'Exhausting effort',g:0}],fn:G=>{G.f=Math.max(0,G.f-10)}},
  t4engineer:{txt:'Your engineer inspected the bridge and shored up the weakest points with timber. A masterwork of improvisation.',efx:[{l:'Engineer bonus!',g:1},{l:'Bridge reinforced',g:1}],fn:G=>{}},
  t5camp:{txt:'The guards kept watch all night. The other fires turned out to be sheep herders — no threat.',efx:[{l:'Safe camp',g:1},{l:'Quiet night',g:0}],fn:G=>{}},
  t5camp_boost:{txt:'Your warrior and scout ran a textbook perimeter. The mysterious fires moved away during the night.',efx:[{l:'Skill bonus!',g:1},{l:'No threat',g:1}],fn:G=>{}},
  t5approach:{txt:'The other fires were friendly Sogdian traders. You shared food and got invaluable road intelligence.',efx:[{l:'New allies!',g:1},{l:'+12 provisions',g:1}],fn:G=>{G.f+=12}},
  t5push:{txt:'Pushing through the night was exhausting but you reached a caravanserai by dawn.',efx:[{l:'Arrived safely',g:1},{l:'−15 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-15)}},
  t6press:{txt:'The ash fall was miserable. Two merchants fell ill briefly but the caravan pressed through.',efx:[{l:'Made it',g:1},{l:'−10 prov, minor illness',g:0}],fn:G=>{G.f=Math.max(0,G.f-10);if(Math.random()<.25&&G.m>1)G.m--}},
  t6masks:{txt:'Your healer\'s cloth filters made breathing possible. The caravan walked through the ash in relative comfort.',efx:[{l:'Healer bonus!',g:1},{l:'−5 provisions only',g:0}],fn:G=>{G.f=Math.max(0,G.f-5)}},
  t6seal:{txt:'Your engineer sealed the wagons tightly. When you emerged three days later, the cargo was pristine.',efx:[{l:'Engineer bonus!',g:1},{l:'−15 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-15)}},
  t7trade:{txt:'The mahout traded Eastern spice knowledge for your Roman metalwork. A good exchange.',efx:[{l:'Information traded',g:1},{l:'−8 cargo, +road knowledge',g:1}],fn:G=>{G.c=Math.max(0,G.c-8);G.f+=8}},
  t7scholar:{txt:'The scholarly exchange lasted a full day. Your scholar returned with detailed notes on the next three waypoints.',efx:[{l:'Scholar bonus!',g:1},{l:'+road intelligence',g:1}],fn:G=>{G.f+=5;G.g+=10}},
  t7pass:{txt:'You shared a meal and moved on. Simple pleasures on a long road.',efx:[{l:'Pleasant encounter',g:1},{l:'No change',g:0}],fn:G=>{G.f+=5}},
  t8wait:{txt:'You waited five days for the migration to clear. The delay cost provisions but the road was then yours.',efx:[{l:'Road cleared',g:1},{l:'−20 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-20)}},
  t8negotiate:{txt:'Your diplomat found the tribe\'s elder and negotiated a gap in the herds. You passed through in two hours.',efx:[{l:'Diplomat bonus!',g:1},{l:'−5 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-5)}},
  t8ford:{txt:'Your navigator found the exact ford ahead of the migration. You crossed before the herds arrived.',efx:[{l:'Navigator bonus!',g:1},{l:'−12 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-12)}},
  // ── Market ──
  mp:{txt:'You resupplied generously. Your provisions are now well-stocked for the hard road ahead.',efx:[{l:'Resupplied',g:1},{l:'−25 denarii, +30 provisions',g:1}],fn:G=>{G.g=Math.max(0,G.g-25);G.f+=30}},
  mp_t:{txt:'Your trader found a bulk discount. You restocked provisions for almost half the usual price.',efx:[{l:'Trader bonus!',g:1},{l:'−12 denarii, +30 provisions',g:1}],fn:G=>{G.g=Math.max(0,G.g-12);G.f+=30}},
  ms:{txt:'Roman glassware for Eastern silk — a classic Silk Road trade. Both sides were satisfied.',efx:[{l:'Trade complete',g:1},{l:'−5 cargo, +30 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-5);G.g+=30}},
  ms_t:{txt:'Your trader negotiated the exchange rate upward. The silk you received was worth double what you gave.',efx:[{l:'Trader bonus!',g:1},{l:'−3 cargo, +40 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-3);G.g+=40}},
  mh:{txt:'An experienced guard joined your caravan for the next leg. His knowledge of the road proved valuable.',efx:[{l:'Guard hired',g:1},{l:'−20 denarii, +protection',g:1}],fn:G=>{G.g=Math.max(0,G.g-20)}},
  m2gems:{txt:'The gems were genuine. Your scholar was right — they are worth five times what you paid.',efx:[{l:'Gems acquired!',g:1},{l:'−50 denarii, +35 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-50);G.c+=35}},
  m2gems_risk:{txt:'Half the gems turned out to be glass imitations. A costly lesson in caution.',efx:[{l:'Partial fraud',g:0},{l:'−50 denarii, +15 cargo',g:0}],fn:G=>{G.g=Math.max(0,G.g-50);G.c+=15}},
  m2trade:{txt:'The silk-for-gems trade was well-received in every subsequent market you visited.',efx:[{l:'Trade complete',g:1},{l:'−20 cargo, +20 cargo',g:0}],fn:G=>{G.c+=5}},
  m2decline:{txt:'You declined. A week later you heard the merchant had been arrested for fraud. A lucky escape.',efx:[{l:'Wise caution',g:1},{l:'No change',g:0}],fn:G=>{}},
  m3contracts:{txt:'The contracts were valid. When you reach Chang\'an, the silk will await you at far below market price.',efx:[{l:'Contracts secured!',g:1},{l:'−45 denarii, +40 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-45);G.c+=40}},
  m3one:{txt:'One contract was modest but sound. A small but reliable gain.',efx:[{l:'Contract secured',g:1},{l:'−20 denarii, +15 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-20);G.c+=15}},
  m3pass:{txt:'You walked away. Two weeks later you heard the contracts had been contested in court.',efx:[{l:'Wisely avoided',g:1},{l:'No change',g:0}],fn:G=>{}},
  m4sell:{txt:'The Romans in this city were desperate for wine. You sold every amphora at three times the Roman price.',efx:[{l:'Premium sale!',g:1},{l:'−20 cargo, +50 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-20);G.g+=50}},
  m4sell_t:{txt:'Your trader created a bidding war. The final price was five times Roman market value.',efx:[{l:'Trader bonus!',g:1},{l:'−20 cargo, +70 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-20);G.g+=70}},
  m4half:{txt:'You sold half the wine at premium prices and kept the best for Rome.',efx:[{l:'Balanced decision',g:1},{l:'−10 cargo, +25 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-10);G.g+=25}},
  m4hold:{txt:'You held your wine. Three waypoints later, a Roman consul bought the entire stock at an extraordinary price.',efx:[{l:'Patience rewarded',g:1},{l:'+40 denarii (later)',g:1}],fn:G=>{G.g+=40}},
  m5buy:{txt:'The maps were extraordinary — Imperial courier routes known to no other traveller. You saved days.',efx:[{l:'Skill bonus!',g:1},{l:'−30 denarii, +route advantage',g:1}],fn:G=>{G.g=Math.max(0,G.g-30);G.f+=8}},
  m5partial:{txt:'The partial map covered your next two legs perfectly. A good investment.',efx:[{l:'Navigator bonus!',g:1},{l:'−12 denarii',g:0}],fn:G=>{G.g=Math.max(0,G.g-12);G.f+=5}},
  m5copy:{txt:'Your scholar copied the key sections by memory with surprising accuracy. No coin spent.',efx:[{l:'Scholar bonus!',g:1},{l:'Free knowledge',g:1}],fn:G=>{G.f+=3}},
  m6buy:{txt:'The porcelain survived the journey immaculately packed. In Rome it would sell for a fortune.',efx:[{l:'Skill bonus!',g:1},{l:'−60 denarii, +25 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-60);G.c+=25}},
  m6half:{txt:'The half-load of porcelain was carefully chosen — the finest pieces. All survived the road.',efx:[{l:'Good selection',g:1},{l:'−30 denarii, +12 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-30);G.c+=12}},
  m6decline:{txt:'You passed on the porcelain. Your wagon space was better used for easier cargo.',efx:[{l:'Practical decision',g:1},{l:'No change',g:0}],fn:G=>{}},
  m7buy:{txt:'The alchemist\'s substances turned out to include genuine mithridate and rare Persian salves. A real find.',efx:[{l:'Skill bonus!',g:1},{l:'−40 denarii, +20 cargo',g:1}],fn:G=>{G.g=Math.max(0,G.g-40);G.c+=20}},
  m7sample:{txt:'The sample proved genuine. Your healer confirmed three of the substances had real medical value.',efx:[{l:'Healer bonus!',g:1},{l:'−10 provisions, +8 cargo',g:1}],fn:G=>{G.f=Math.max(0,G.f-10);G.c+=8}},
  m7decline:{txt:'You declined the strange wares. Wise caution — another merchant who bought them found them worthless.',efx:[{l:'Wise caution',g:1},{l:'No change',g:0}],fn:G=>{}},
  // ── Cultural ──
  c1join:{txt:'You feasted with the locals. A city elder, delighted by your Roman tales, gifted you provisions for the road.',efx:[{l:'Diplomat bonus!',g:1},{l:'−10 prov, +18 prov gift',g:1}],fn:G=>{G.f+=8}},
  c1observe:{txt:'You watched from a respectful distance. The festival was beautiful, and you rested well.',efx:[{l:'Rested',g:1},{l:'No change',g:0}],fn:G=>{}},
  c1sell:{txt:'You set up a small market stall amid the festival crowd. Roman novelties sold for remarkable prices.',efx:[{l:'Trader bonus!',g:1},{l:'−8 cargo, +20 denarii',g:1}],fn:G=>{G.c=Math.max(0,G.c-8);G.g+=20}},
  c2welcome:{txt:'The scholar\'s geographical knowledge proved invaluable. He knew every water source and safe camp along the next three legs.',efx:[{l:'Skill bonus!',g:1},{l:'+15 provisions saved',g:1}],fn:G=>{G.f+=15}},
  c2charge:{txt:'He paid for passage and shared his knowledge freely anyway. A gentlemanly arrangement.',efx:[{l:'Paid passage',g:1},{l:'+10 denarii, +8 provisions',g:1}],fn:G=>{G.g+=10;G.f+=8}},
  c2decline:{txt:'You declined the extra burden. The road ahead was harder without his geographical knowledge.',efx:[{l:'Passed',g:1},{l:'No gain',g:0}],fn:G=>{}},
  c3accept:{txt:'You carried the relic to Antioch. The temple monks greeted you with ceremony and generous payment.',efx:[{l:'Mission complete!',g:1},{l:'+20 denarii reward',g:1}],fn:G=>{G.g+=20}},
  c3negotiate:{txt:'Your combined skills secured the payment upfront. The monks were delighted by your honesty.',efx:[{l:'Skill bonus!',g:1},{l:'+30 denarii',g:1}],fn:G=>{G.g+=30}},
  c3decline:{txt:'You declined. The monk found another caravan. You wondered sometimes about the relic\'s fate.',efx:[{l:'Declined',g:1},{l:'No change',g:0}],fn:G=>{}},
  c4rest:{txt:'Three days of rest and city trading. Your trader made deals that more than covered the provisions spent.',efx:[{l:'Trader bonus!',g:1},{l:'+25 denarii from trade',g:1}],fn:G=>{G.g+=25;G.f=Math.max(0,G.f-15)}},
  c4negotiate:{txt:'Your diplomat negotiated a one-day stay. The ruler accepted graciously and gave you a fast-pass letter for his territory.',efx:[{l:'Diplomat bonus!',g:1},{l:'Stay shortened, +letter',g:1}],fn:G=>{}},
  c4sneak:{txt:'Your scout got you out before dawn. The ruler was briefly furious but his territory ended two days later.',efx:[{l:'Scout bonus!',g:1},{l:'Minor political risk',g:0}],fn:G=>{if(Math.random()<.2)G.g=Math.max(0,G.g-10)}},
  c5visit:{txt:'The oracle described a bandit ambush at the next river crossing. You prepared well and avoided it.',efx:[{l:'Diplomatic wisdom!',g:1},{l:'−15 denarii, saved losses',g:1}],fn:G=>{G.g=Math.max(0,G.g-15);G.c+=10}},
  c5send:{txt:'Your scout visited alone. He returned with genuine intelligence about a blocked road ahead.',efx:[{l:'Scout bonus!',g:1},{l:'+navigation info',g:1}],fn:G=>{G.f+=8}},
  c5ignore:{txt:'You marched on. Three days later you walked into the very ambush the oracle would have warned you about.',efx:[{l:'Ignored oracle',g:0},{l:'−15 cargo (ambush)',g:0}],fn:G=>{if(Math.random()<.5)G.c=Math.max(0,G.c-15)}},
  c6welcome:{txt:'The musician\'s playing lifted everyone\'s spirits. The caravan moved slower but morale was extraordinary.',efx:[{l:'Morale boost!',g:1},{l:'−8 provisions',g:0}],fn:G=>{G.f=Math.max(0,G.f-8);G.c+=5}},
  c6camp:{txt:'Evening performances became the highlight of each day. Good compromise.',efx:[{l:'Pleasant journey',g:1},{l:'No change',g:0}],fn:G=>{}},
