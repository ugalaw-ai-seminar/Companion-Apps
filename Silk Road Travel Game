   ch:[{t:'Attempt the pass before it worsens.',c:'⚔️ High risk',b:['scout','warrior'],o:'wb'},
       {t:'Take the longer southern route.',c:'🌾 −25 provisions',b:['navigator'],o:'wl'},
       {t:'Winter in a nearby village.',c:'💰 −35 denarii',b:[],o:'wn'}]},

  {id:'w3',type:'weather',icon:'🌊',tag:'tag-weather',title:'Flooded River Crossing',
   text:'Spring floods have turned a normally calm river into a raging torrent. Your wagons cannot cross safely.',
   skillBonus:{navigator:'Your navigator knows of a safer ford upstream.',warrior:'Your warrior can help secure ropes and guide wagons.',engineer:'Your engineer can build a temporary raft crossing.'},
   ch:[{t:'Attempt the crossing with roped wagons.',c:'📦 Risk cargo',b:['warrior'],o:'w3cross'},
       {t:'Find the ford upstream — adds days.',c:'🌾 −18 provisions',b:['navigator'],o:'w3ford'},
       {t:'Pay ferrymen to carry everything.',c:'💰 −30 denarii',b:['trader'],o:'w3ferry'}]},

  {id:'w4',type:'weather',icon:'⚡',tag:'tag-weather',title:'Lightning Strikes the Camp',
   text:'A ferocious lightning storm swept through camp in the night, setting two wagons ablaze and scattering pack animals.',
   skillBonus:{warrior:'Your warrior quickly organises the crew to fight the fire.',scout:'Your scout tracked and recovered most of the lost animals.',engineer:'Your engineer knows how to control and contain the blaze.'},
   ch:[{t:'Fight the fire — save the cargo.',c:'📦 Risk 20 cargo',b:['warrior','engineer'],o:'w4fight'},
       {t:'Let the wagons burn and save the animals.',c:'📦 −20 cargo certain',b:['scout'],o:'w4animals'},
       {t:'Grab essentials and abandon the wagons.',c:'📦 −30 cargo',b:[],o:'w4abandon'}]},

  {id:'w5',type:'weather',icon:'🌫️',tag:'tag-weather',title:'Lost in the Desert Fog',
   text:'A thick morning fog has descended. Your caravan has been marching in circles for six hours. Provisions are running thin.',
   skillBonus:{navigator:'Your navigator can use the stars once the fog lifts slightly.',scout:'Your scout can read animal tracks to find the right path.'},
   ch:[{t:'Camp and wait for the fog to lift.',c:'🌾 −12 provisions',b:[],o:'w5wait'},
       {t:'Follow your navigator\'s star readings.',c:'🧭 Requires skill',b:['navigator'],o:'w5nav'},
       {t:'Follow animal tracks out.',c:'🔭 Requires skill',b:['scout'],o:'w5tracks'}]},

  {id:'w6',type:'weather',icon:'🌬️',tag:'tag-weather',title:'The Gobi Winds',
   text:'Furious gale-force winds have been howling for four days across the Gobi. Your tents have shredded and camels refuse to walk.',
   skillBonus:{engineer:'Your engineer can reinforce the wagons and lash down cargo.',navigator:'Your navigator knows the winds will shift in two days if you wait at the right altitude.'},
   ch:[{t:'Push through against the winds.',c:'🌾 −18 provisions, 📦 −10 cargo',b:['warrior'],o:'w6push'},
       {t:'Shelter and wait for the winds to ease.',c:'🌾 −14 provisions',b:['navigator'],o:'w6wait'},
       {t:'Have the engineer fortify everything and march slow.',c:'💰 −10 denarii',b:['engineer'],o:'w6fortify'}]},

  {id:'w7',type:'weather',icon:'🌧️',tag:'tag-weather',title:'Monsoon Rains',
   text:'Torrential rains have turned the mountain road into a river of mud. Wagons sink to their axles. The silk cargo risks being soaked.',
   skillBonus:{engineer:'Your engineer can lay timber tracks to pull wagons through.',navigator:'Your navigator knows a drier high ridge path.'},
   ch:[{t:'Press on — accept the mud and the losses.',c:'📦 −15 cargo',b:[],o:'w7press'},
       {t:'Have the engineer build a corduroy road.',c:'💰 −12 denarii',b:['engineer'],o:'w7corduroy'},
       {t:'Take the ridge path — longer but dry.',c:'🌾 −16 provisions',b:['navigator'],o:'w7ridge'}]},

  {id:'w8',type:'weather',icon:'🌅',tag:'tag-weather',title:'Drought at the Oasis',
   text:'The oasis marked on your maps has dried completely. Your provisions are low and the next water source is six days away.',
   skillBonus:{navigator:'Your navigator recalls an alternate water source from old maps.',healer:'Your healer can devise strict rationing to extend your water supply.'},
   ch:[{t:'Race to the next known water source.',c:'👥 Risk collapse',b:['navigator'],o:'w8race'},
       {t:'Implement strict healer-supervised rationing.',c:'🌾 −20 provisions',b:['healer'],o:'w8ration'},
       {t:'Dig at the dry oasis bed — water may remain underground.',c:'⚙️ Uncertain',b:['engineer'],o:'w8dig'}]},

  // ── POLITICAL (8) ──
  {id:'p1',type:'political',icon:'🏛️',tag:'tag-political',title:'The Governor Demands a Cut',
   text:'The regional governor has heard of your valuable cargo. His representative blocks the city gates demanding a "tax".',
   skillBonus:{diplomat:'Your diplomat can invoke Silk Road treaty rights.',trader:'Your trader can negotiate the payment down substantially.'},
   ch:[{t:'Pay the corrupt official.',c:'💰 −40 denarii',b:[],o:'pg'},
       {t:'Invoke Roman diplomatic rights.',c:'🎲 Risky gamble',b:['diplomat'],o:'pr'},
       {t:'Negotiate the tax down.',c:'💰 −20 denarii',b:['trader'],o:'pn'}]},

  {id:'p2',type:'political',icon:'🤝',tag:'tag-political',title:'A Sogdian Alliance',
   text:'A wealthy Sogdian merchant offers to merge his caravan with yours — extra guards and provisions, but political complications with his enemies.',
   skillBonus:{trader:'Your trader can negotiate an extremely profitable arrangement.',diplomat:'Your diplomat can navigate the political complications.'},
   ch:[{t:'Accept the alliance fully.',c:'📦 +20 cargo value',b:[],o:'pa'},
       {t:'Negotiate a limited trade arrangement.',c:'💰 +15 denarii',b:['trader','diplomat'],o:'pd2'},
       {t:'Decline — trust no one.',c:'No change',b:[],o:'pd'}]},

  {id:'p3',type:'political',icon:'👑',tag:'tag-political',title:'The Khan\'s Invitation',
   text:'A local Khan has heard of your Roman goods. He invites your company to feast at his court — a great honour, but his motives are unclear.',
   skillBonus:{diplomat:'Your diplomat knows court protocol intimately.',trader:'Your trader can turn this into a lucrative business meeting.'},
   ch:[{t:'Attend and bring lavish gifts.',c:'📦 −8 cargo',b:['diplomat'],o:'kf'},
       {t:'Attend empty-handed with goodwill.',c:'🎲 Social risk',b:['diplomat'],o:'ke'},
       {t:'Send a merchant envoy and continue.',c:'👥 Minor risk',b:['trader'],o:'kv'}]},

  {id:'p4',type:'political',icon:'⚖️',tag:'tag-political',title:'Border Customs Seizure',
   text:'A customs official at the Persian border claims your paperwork is invalid and threatens to seize your entire cargo.',
   skillBonus:{diplomat:'Your diplomat can challenge this legally.',trader:'Your trader has experience greasing administrative wheels.',scholar:'Your scholar can find the relevant legal precedents.'},
   ch:[{t:'Produce your Senate documentation.',c:'📜 Depends on papers',b:['diplomat','scholar'],o:'p4docs'},
       {t:'Bribe the customs official.',c:'💰 −25 denarii',b:['trader'],o:'p4bribe'},
       {t:'Contest the seizure loudly in public.',c:'🎲 High risk, high reward',b:['diplomat','warrior'],o:'p4contest'}]},

  {id:'p5',type:'political',icon:'🕊️',tag:'tag-political',title:'Feuding City-States',
   text:'Two rival city-states are at war with each other. Both roads pass through contested territory — your caravan is caught in the middle.',
   skillBonus:{diplomat:'Your diplomat can negotiate safe passage with both sides.',navigator:'Your navigator knows a path that bypasses both territories.'},
   ch:[{t:'Negotiate passage with both parties.',c:'🎭 Diplomatic challenge',b:['diplomat'],o:'p5negotiate'},
       {t:'Take the long route through the mountains.',c:'🌾 −22 provisions',b:['navigator'],o:'p5mountains'},
       {t:'Pay tribute to whichever side controls the road.',c:'💰 −30 denarii',b:[],o:'p5tribute'}]},

  {id:'p6',type:'political',icon:'📜',tag:'tag-political',title:'Forged Trade Documents',
   text:'A shady merchant is selling forged Imperial Chinese travel documents. They could get you through multiple checkpoints — or land you in a dungeon.',
   skillBonus:{scholar:'Your scholar can assess the authenticity of documents.',trader:'Your trader knows the risk is worth it if the price is right.'},
   ch:[{t:'Buy the forged documents and risk it.',c:'💰 −15 denarii, 🎲 risk',b:['trader'],o:'p6buy'},
       {t:'Have your scholar authenticate them first.',c:'📚 Scholar check',b:['scholar'],o:'p6check'},
       {t:'Report the forger to the authorities.',c:'💰 +10 reward',b:['diplomat'],o:'p6report'}]},

  {id:'p7',type:'political',icon:'🏰',tag:'tag-political',title:'A City Under Siege',
   text:'The city you planned to resupply in is under siege by a rival kingdom. The gates are sealed and arrows fly from the walls.',
   skillBonus:{navigator:'Your navigator can find a way to the besieging army\'s market camp.',engineer:'Your engineer recognises a structural weakness in the siege lines.'},
   ch:[{t:'Trade with the besieging army\'s camp.',c:'💰 −10 denarii, +5 provisions',b:['navigator','trader'],o:'p7siege'},
       {t:'Wait out the siege outside the walls.',c:'🌾 −20 provisions',b:[],o:'p7wait'},
       {t:'Sneak through the siege lines at night.',c:'⚔️ High risk',b:['scout','engineer'],o:'p7sneak'}]},

  {id:'p8',type:'political',icon:'⚔️',tag:'tag-political',title:'Imperial Conscription',
   text:'A Han general stops your caravan and threatens to conscript your guards into his army. Without them, you are defenceless.',
   skillBonus:{diplomat:'Your diplomat can invoke foreign merchant protections.',warrior:'Your warrior can negotiate man-to-man with the general.',scholar:'Your scholar knows the relevant Han imperial law.'},
   ch:[{t:'Invoke foreign diplomatic immunity.',c:'🎭 Requires boldness',b:['diplomat','scholar'],o:'p8invoke'},
       {t:'Offer a substantial "donation" to the general\'s campaign.',c:'💰 −35 denarii',b:['trader'],o:'p8donate'},
       {t:'Comply — lose the guards but keep moving.',c:'👥 Lose protection',b:[],o:'p8comply'}]},

  // ── TRAVEL (8) ──
  {id:'t1',type:'travel',icon:'🌅',tag:'tag-travel',title:'A Fork in the Road',
   text:'Two roads diverge before you. The northern route is faster but passes through disputed territory. The southern road winds through fertile lands.',
   skillBonus:{scout:'Your scout can do reconnaissance of the northern road.',navigator:'Your navigator has heard reliable reports from travellers.'},
   ch:[{t:'Take the northern route — speed matters.',c:'⚔️ Battle risk',b:['scout'],o:'tn'},
       {t:'Follow the southern road.',c:'🌾 −10 provisions (longer)',b:['navigator'],o:'ts'},
       {t:'Ask a local shepherd for advice.',c:'💰 −5 denarii',b:[],o:'ta'}]},

  {id:'t2',type:'travel',icon:'🐪',tag:'tag-travel',title:'The Camel Market',
   text:'You have reached a famous camel market. Upgrading your pack animals could carry more cargo across the coming desert.',
   skillBonus:{trader:'Your trader can spot quality animals and negotiate fiercely.',navigator:'Your navigator knows exactly what you\'ll need ahead.'},
   ch:[{t:'Buy two strong Bactrian camels.',c:'💰 −40 denarii',b:['trader'],o:'tc'},
       {t:'Sell excess cargo to travel lighter.',c:'📦 −15, 💰 +20',b:['trader'],o:'tsc'},
       {t:'Move on — no time to bargain.',c:'No change',b:[],o:'tp'}]},

  {id:'t3',type:'travel',icon:'🏔️',tag:'tag-travel',title:'The High Passes of the Pamirs',
   text:'The legendary Pamir mountains loom before you. The high road offers spectacular views — and lethal cold. The low road is murky swampland.',
   skillBonus:{navigator:'Your navigator has crossed these mountains before.',scout:'Your scout can assess conditions before committing.',engineer:'Your engineer can build walkways over the boggy low route.'},
   ch:[{t:'Take the high road through the passes.',c:'❄️ Cold risk',b:['navigator','scout'],o:'t3high'},
       {t:'Take the low marshy route.',c:'🌾 −18 provisions',b:[],o:'t3low'},
       {t:'Rest at the base and hire a guide.',c:'💰 −22 denarii',b:[],o:'t3guide'}]},

  {id:'t4',type:'travel',icon:'🌉',tag:'tag-travel',title:'The Ancient Bridge',
   text:'An ancient stone bridge spans the gorge ahead. It looks weathered — cracks run through the pillars. Your fully loaded wagons may be too heavy.',
   skillBonus:{warrior:'Your warrior can organise a careful crossing.',navigator:'Your navigator knows if there is another crossing nearby.',engineer:'Your engineer can assess structural integrity and reinforce the bridge.'},
   ch:[{t:'Cross slowly, one wagon at a time.',c:'⏳ Time and risk',b:['warrior'],o:'t4slow'},
       {t:'Unload cargo and carry it across by hand.',c:'⏳ Very slow',b:[],o:'t4carry'},
       {t:'Have the engineer assess and reinforce the bridge.',c:'⚙️ Safer crossing',b:['engineer'],o:'t4engineer'}]},

  {id:'t5',type:'travel',icon:'🌠',tag:'tag-travel',title:'A Night in the Open Desert',
   text:'Night has fallen suddenly. Your caravan is exposed in the open desert, and you can see campfires in the dunes — possibly bandits, possibly traders.',
   skillBonus:{scout:'Your scout can determine who those fires belong to.',diplomat:'Your diplomat can approach any strangers safely.'},
   ch:[{t:'Post guards and camp where you are.',c:'⚔️ Risk ambush',b:['warrior','scout'],o:'t5camp'},
       {t:'Approach the other fires to investigate.',c:'🎲 Unknown',b:['scout','diplomat'],o:'t5approach'},
       {t:'Push through the night to reach a town.',c:'🌾 −15 provisions',b:['navigator'],o:'t5push'}]},

  {id:'t6',type:'travel',icon:'🌋',tag:'tag-travel',title:'Volcanic Ash Clouds',
   text:'A distant mountain has erupted. Fine ash fills the air for three days, coating your provisions and making breathing painful.',
   skillBonus:{healer:'Your healer can create cloth filters to help the caravan breathe.',engineer:'Your engineer knows how to seal wagons against the ash.'},
   ch:[{t:'Press on through the ash fall.',c:'🌾 −10 provisions, 👥 risk',b:[],o:'t6press'},
       {t:'Create makeshift filter masks for everyone.',c:'🌾 −5 provisions',b:['healer'],o:'t6masks'},
       {t:'Seal the wagons and wait it out.',c:'💰 −15 denarii',b:['engineer'],o:'t6seal'}]},

  {id:'t7',type:'travel',icon:'🐘',tag:'tag-travel',title:'Elephant Caravan Encounter',
   text:'You encounter a magnificent Indian elephant caravan heading east. Their mahout offers to trade information about the road — his knowledge is invaluable.',
   skillBonus:{trader:'Your trader can arrange a lucrative goods exchange.',scholar:'Your scholar can engage the mahout in a deep conversation about what lies ahead.'},
   ch:[{t:'Trade Roman goods for road intelligence.',c:'📦 −8 cargo, +info',b:['trader'],o:'t7trade'},
       {t:'Invite their scholar to share knowledge.',c:'🌾 −5 provisions',b:['scholar'],o:'t7scholar'},
       {t:'Simply exchange pleasantries and move on.',c:'No change',b:[],o:'t7pass'}]},

  {id:'t8',type:'travel',icon:'🌾',tag:'tag-travel',title:'Nomadic Tribe Crossing',
   text:'A great nomadic tribe is migrating with their herds and blocks the road for miles. Waiting could take a week; negotiating might be faster.',
   skillBonus:{diplomat:'Your diplomat speaks the nomadic tongue and can arrange passage.',navigator:'Your navigator knows a crossing point before the migration route.'},
   ch:[{t:'Wait for the migration to pass.',c:'🌾 −20 provisions',b:[],o:'t8wait'},
       {t:'Negotiate an immediate crossing gap.',c:'🎭 Diplomatic challenge',b:['diplomat'],o:'t8negotiate'},
       {t:'Find the crossing point ahead of the migration.',c:'🌾 −12 provisions',b:['navigator'],o:'t8ford'}]},

  // ── MARKET (7) ──
  {id:'m1',type:'market',icon:'🏪',tag:'tag-market',title:'The Oasis Bazaar',
   text:'You have arrived at a thriving oasis market. Merchants from Persia, India, and China ply their wares. A rare opportunity.',
   skillBonus:{trader:'Your trader can negotiate prices well below market value.'},
   ch:[{t:'Buy extra provisions for the road.',c:'💰 −25 denarii',b:['trader'],o:'mp'},
       {t:'Trade Roman glassware for Eastern silk.',c:'📦 −5, 💰 +30',b:['trader'],o:'ms'},
       {t:'Hire an extra guard for protection.',c:'💰 −20 denarii',b:[],o:'mh'}]},

  {id:'m2',type:'market',icon:'💎',tag:'tag-market',title:'A Rare Opportunity',
   text:'A merchant from India offers you an extraordinary deal — a crate of uncut gemstones for a fraction of their value. He claims he needs cash urgently.',
   skillBonus:{trader:'Your trader can assess the gems\' authenticity.',scholar:'Your scholar recognizes the specific type of gems and knows their true value.'},
   ch:[{t:'Buy the gems — extraordinary profit awaits.',c:'💰 −50 denarii upfront',b:['trader'],o:'m2gems'},
       {t:'Trade half your silk for the gems.',c:'📦 −20 cargo',b:['trader'],o:'m2trade'},
       {t:'Decline — too risky.',c:'No change',b:[],o:'m2decline'}]},

  {id:'m3',type:'market',icon:'📜',tag:'tag-market',title:'The Silk Contracts',
   text:'A Roman merchant who preceded you has left bulk purchase contracts for silk — but he has died en route and his estate offers them at a steep discount.',
   skillBonus:{trader:'Your trader understands contract law and can negotiate.',diplomat:'Your diplomat can verify the legality of the contracts.',scholar:'Your scholar can read the contract in its original language.'},
   ch:[{t:'Buy the contracts — enormous upside.',c:'💰 −45 denarii',b:['trader','diplomat'],o:'m3contracts'},
       {t:'Purchase just one contract conservatively.',c:'💰 −20 denarii',b:['trader'],o:'m3one'},
       {t:'Walk away — too complicated.',c:'No change',b:[],o:'m3pass'}]},

  {id:'m4',type:'market',icon:'🍷',tag:'tag-market',title:'Roman Wine in the East',
   text:'Your Roman wine amphorae have caused a sensation at this bazaar. Bidding has broken out. Do you sell now or hold for the Roman market?',
   skillBonus:{trader:'Your trader knows the optimal moment to sell.'},
   ch:[{t:'Sell everything here at the inflated price.',c:'📦 −20 cargo, 💰 +50',b:['trader'],o:'m4sell'},
       {t:'Sell half and keep the rest for Rome.',c:'📦 −10 cargo, 💰 +25',b:[],o:'m4half'},
       {t:'Hold — Rome will pay even more.',c:'No change',b:[],o:'m4hold'}]},

  {id:'m5',type:'market',icon:'🧭',tag:'tag-market',title:'The Map Merchant',
   text:'A blind old cartographer is selling what he claims are the most accurate maps of the road ahead — routes used only by the Emperor\'s own couriers.',
   skillBonus:{navigator:'Your navigator can immediately assess the maps\' value.',scholar:'Your scholar can verify the maps\' authenticity by comparing details.'},
   ch:[{t:'Purchase the full map collection.',c:'💰 −30 denarii',b:['navigator','scholar'],o:'m5buy'},
       {t:'Buy just the segment you need next.',c:'💰 −12 denarii',b:['navigator'],o:'m5partial'},
       {t:'Copy what you can by memory and move on.',c:'No change',b:['scholar'],o:'m5copy'}]},

  {id:'m6',type:'market',icon:'🔮',tag:'tag-market',title:'Chinese Porcelain Windfall',
   text:'A desperate Chinese merchant offers you his entire stock of exquisite blue-and-white porcelain — it will be priceless in Rome, but it\'s heavy and fragile.',
   skillBonus:{trader:'Your trader knows the Rome porcelain market intimately.',engineer:'Your engineer can construct protective crating for the fragile pieces.'},
   ch:[{t:'Buy everything — Rome will pay a fortune.',c:'💰 −60 denarii, 📦 +25',b:['trader','engineer'],o:'m6buy'},
       {t:'Buy a carefully selected half-load.',c:'💰 −30 denarii, 📦 +12',b:['trader'],o:'m6half'},
       {t:'Decline — too heavy and fragile.',c:'No change',b:[],o:'m6decline'}]},

  {id:'m7',type:'market',icon:'⚗️',tag:'tag-market',title:'The Alchemist\'s Wares',
   text:'A Sogdian alchemist offers strange substances he claims are miraculous medicines — worth a fortune to Roman physicians. The science is uncertain.',
   skillBonus:{healer:'Your healer can assess whether these substances are genuinely valuable.',scholar:'Your scholar recognises some of the ingredients as legitimately rare.'},
   ch:[{t:'Purchase the full lot on good faith.',c:'💰 −40 denarii',b:['healer','scholar'],o:'m7buy'},
       {t:'Trade provisions for a small sample.',c:'🌾 −10 provisions',b:['healer'],o:'m7sample'},
       {t:'Decline the strange wares.',c:'No change',b:[],o:'m7decline'}]},

  // ── CULTURAL (10) ──
  {id:'c1',type:'cultural',icon:'🎎',tag:'tag-cultural',title:'A Festival Invitation',
   text:'You arrive in a city during its annual spring festival. The host family invites your entire caravan to participate in the celebration.',
   skillBonus:{diplomat:'Your diplomat\'s cultural knowledge ensures you make the best impression.'},
   ch:[{t:'Join fully — eat, drink, celebrate.',c:'🌾 −10 provisions',b:['diplomat'],o:'c1join'},
       {t:'Politely observe from the periphery.',c:'No change',b:[],o:'c1observe'},
       {t:'Use the festival crowd to sell cargo.',c:'📦 −8 cargo, 💰 +20',b:['trader'],o:'c1sell'}]},

  {id:'c2',type:'cultural',icon:'📚',tag:'tag-cultural',title:'The Scholar\'s Request',
   text:'A learned Persian scholar asks to join your caravan to Ctesiphon in exchange for his remarkable geographical knowledge of the roads ahead.',
   skillBonus:{navigator:'Your navigator can immediately use the geographical data.',diplomat:'Your diplomat can broker a more valuable exchange.',scholar:'Your scholar immediately connects with him and gets extra knowledge.'},
   ch:[{t:'Welcome the scholar aboard.',c:'🌾 −5 provisions',b:['navigator','diplomat','scholar'],o:'c2welcome'},
       {t:'Accept him but charge for passage.',c:'💰 +10 denarii',b:['trader'],o:'c2charge'},
       {t:'Politely decline the extra burden.',c:'No change',b:[],o:'c2decline'}]},

  {id:'c3',type:'cultural',icon:'🏺',tag:'tag-cultural',title:'The Sacred Relic',
   text:'A monk approaches your caravan with a small bronze statue — a sacred relic he needs transported to a temple in Antioch. He promises a reward.',
   skillBonus:{diplomat:'Your diplomat can negotiate the reward upfront.',scholar:'Your scholar knows the relic is genuinely valuable and can verify the monk\'s legitimacy.'},
   ch:[{t:'Accept — carry the relic to Antioch.',c:'📦 Minor weight',b:['diplomat'],o:'c3accept'},
       {t:'Accept but negotiate the reward first.',c:'💰 Guarantee payment',b:['diplomat','trader'],o:'c3negotiate'},
       {t:'Decline — too many complications.',c:'No change',b:[],o:'c3decline'}]},

  {id:'c4',type:'cultural',icon:'🌺',tag:'tag-cultural',title:'The Garden City',
   text:'You pass through a legendary garden city whose ruler welcomes trading caravans. However, he insists all visitors rest for three days.',
   skillBonus:{trader:'Your trader can use the rest period for lucrative city trade.',diplomat:'Your diplomat can negotiate a shorter compulsory stay.'},
   ch:[{t:'Rest three days and enjoy the hospitality.',c:'🌾 −15 provisions',b:['trader'],o:'c4rest'},
       {t:'Negotiate to stay just one day.',c:'🎭 Diplomatic challenge',b:['diplomat'],o:'c4negotiate'},
       {t:'Sneak out at dawn on the second night.',c:'⚠️ Risk offending the ruler',b:['scout'],o:'c4sneak'}]},

  {id:'c5',type:'cultural',icon:'🔮',tag:'tag-cultural',title:'The Oracle of the Desert',
   text:'Locals say a desert oracle lives two days off the road. She supposedly knows of threats ahead and charges whatever you can afford.',
   skillBonus:{navigator:'Your navigator calculates the detour costs precisely.',diplomat:'Your diplomat believes the oracle has real intelligence value.'},
   ch:[{t:'Visit the oracle.',c:'💰 −15 denarii, ⏳ time',b:['diplomat'],o:'c5visit'},
       {t:'Send one merchant to visit alone.',c:'👥 Minor risk',b:['scout'],o:'c5send'},
       {t:'Ignore superstition and march on.',c:'No change',b:[],o:'c5ignore'}]},

  {id:'c6',type:'cultural',icon:'🎵',tag:'tag-cultural',title:'The Silk Road Musician',
   text:'A celebrated musician from Samarkand attaches himself to your caravan. His playing lifts morale enormously — but he slows you down.',
   skillBonus:{diplomat:'Your diplomat knows how to encourage the musician while keeping pace.',trader:'Your trader sees opportunity: the musician\'s performances attract business.'},
   ch:[{t:'Welcome him gladly — morale matters.',c:'🌾 −8 provisions (slower)',b:['diplomat'],o:'c6welcome'},
       {t:'Let him perform only at campsites.',c:'No change',b:[],o:'c6camp'},
       {t:'Turn his performances into a revenue event.',c:'💰 +18 denarii',b:['trader'],o:'c6perform'}]},

  {id:'c7',type:'cultural',icon:'🌙',tag:'tag-cultural',title:'The Ramadan Feast',
   text:'Your caravan arrives at a Sogdian city during a great religious feast. The city is celebrating and all caravansaries are full and free — but roads are closed.',
   skillBonus:{diplomat:'Your diplomat can navigate the cultural celebrations respectfully.',scholar:'Your scholar speaks the local dialect and can arrange accommodation quickly.'},
   ch:[{t:'Participate fully in the feast and rest.',c:'🌾 −10 provisions (gained hospitality)',b:['scholar'],o:'c7feast'},
       {t:'Camp outside the city and rest freely.',c:'🌾 −5 provisions',b:[],o:'c7camp'},
       {t:'Find a way through the closed roads.',c:'💰 −15 denarii',b:['navigator','diplomat'],o:'c7through'}]},

