<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Via Sericae — The Silk Road</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

:root {
  --gold:#c9a84c; --gold-l:#e8c97a; --gold-d:#8b6914;
  --parch:#f4e8c1; --parch-d:#e0cc94;
  --ink:#2c1810;
  --blood:#8b1a1a; --blood-l:#c0392b;
  --stone:#5c4a32; --stone-l:#8b7355;
  --sky:#2c5364; --sky-l:#4a8fa8;
  --grn:#2d5a27; --grn-l:#4a8c42;
  --purple:#6b2fa0; --purple-l:#9b59d0;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:#120b03;font-family:'Crimson Text',serif;color:var(--ink);min-height:100vh;overflow-x:hidden}

/* ── STARS ── */
#stars{position:fixed;inset:0;z-index:0;pointer-events:none}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--dur,3s) var(--del,0s) infinite}
@keyframes twinkle{0%,100%{opacity:.2}50%{opacity:1}}

/* ── ANIMATED BACKGROUNDS ── */
#bg-layer{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}

/* Desert dunes */
.dune{position:absolute;bottom:0;border-radius:50% 50% 0 0;opacity:.18}
.dune1{width:140%;height:160px;background:linear-gradient(180deg,#c9a84c,#8b6914);left:-20%;animation:duneDrift 18s ease-in-out infinite alternate}
.dune2{width:120%;height:110px;background:linear-gradient(180deg,#e8c97a,#c9a84c);left:-10%;animation:duneDrift 25s ease-in-out infinite alternate-reverse}
.dune3{width:100%;height:70px;background:linear-gradient(180deg,#f4e8c1,#e8c97a);left:0;animation:duneDrift 12s ease-in-out infinite alternate}
@keyframes duneDrift{0%{transform:translateX(0)}100%{transform:translateX(3%)}}

/* ── APP ── */
#app{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:20px 16px 80px}
.screen{animation:screenIn .5s cubic-bezier(.22,1,.36,1)}
@keyframes screenIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ── TITLE ── */
#screen-title{text-align:center;padding:36px 20px;display:flex;flex-direction:column;align-items:center;gap:18px}
.emblem{width:120px;height:120px;background:conic-gradient(from 0deg,#8b6914,#e8c97a,#c9a84c,#8b6914);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:58px;border:3px solid var(--gold-l);box-shadow:0 0 50px rgba(201,168,76,.6),inset 0 0 30px rgba(0,0,0,.3);animation:spinGlow 8s linear infinite}
@keyframes spinGlow{0%{filter:drop-shadow(0 0 8px rgba(201,168,76,.4))}50%{filter:drop-shadow(0 0 22px rgba(201,168,76,.9))}100%{filter:drop-shadow(0 0 8px rgba(201,168,76,.4))}}
.t-latin{font-family:'Cinzel',serif;color:var(--gold-l);font-size:12px;letter-spacing:6px;opacity:.8}
.t-main{font-family:'Cinzel',serif;color:var(--gold);font-size:clamp(34px,7vw,58px);font-weight:900;line-height:1;text-shadow:0 0 40px rgba(201,168,76,.7),0 2px 0 rgba(0,0,0,.5)}
.t-sub{font-family:'Cinzel',serif;color:var(--gold-l);font-size:clamp(13px,3vw,19px);letter-spacing:4px;opacity:.85}
.t-route{font-family:'Cinzel',serif;color:var(--gold);font-size:13px;letter-spacing:2px;opacity:.6;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.2);padding:6px 16px;border-radius:20px}
.t-desc{background:rgba(244,232,193,.06);border:1px solid rgba(201,168,76,.25);border-radius:10px;padding:18px 24px;color:var(--parch);font-size:16px;line-height:1.75;max-width:580px;font-style:italic}
.divider{color:var(--gold);font-size:20px;opacity:.5;letter-spacing:14px}

/* ── SETUP ── */
#screen-setup{padding:20px}
.setup-title{font-family:'Cinzel',serif;color:var(--gold);font-size:22px;font-weight:700;text-align:center;margin-bottom:6px}
.setup-sub{text-align:center;color:rgba(244,232,193,.6);font-size:14px;margin-bottom:24px;font-style:italic}
.chars-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-bottom:24px}
.char-card{background:rgba(30,18,8,.8);border:1px solid rgba(201,168,76,.25);border-radius:12px;padding:18px;transition:border-color .2s}
.char-card:hover{border-color:rgba(201,168,76,.5)}
.char-card-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.char-avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;border:2px solid rgba(201,168,76,.4);background:rgba(201,168,76,.1)}
.char-name-inp{background:rgba(244,232,193,.06);border:1px solid rgba(201,168,76,.3);border-radius:6px;padding:8px 12px;color:var(--parch);font-family:'Cinzel',serif;font-size:14px;width:100%;outline:none;letter-spacing:1px}
.char-name-inp:focus{border-color:var(--gold)}
.char-name-inp::placeholder{opacity:.35}
.skill-label{font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:8px}
.skills-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.skill-opt{display:flex;align-items:center;gap:6px;cursor:pointer;padding:6px 8px;border-radius:6px;border:1px solid rgba(201,168,76,.15);background:rgba(244,232,193,.03);transition:all .2s;position:relative}
.skill-opt:hover{background:rgba(201,168,76,.1);border-color:rgba(201,168,76,.4)}
.skill-opt.active{background:rgba(201,168,76,.15);border-color:var(--gold)}
.skill-opt input{position:absolute;opacity:0;pointer-events:none}
.skill-icon{font-size:15px}
.skill-name{font-family:'Cinzel',serif;font-size:9px;color:var(--parch);letter-spacing:.5px}
.skill-desc-s{font-size:10px;color:rgba(244,232,193,.4);margin-top:1px}
.skill-limit{font-size:11px;color:rgba(201,168,76,.5);text-align:center;margin-top:6px;font-style:italic}

/* ── BUTTONS ── */
.btn{font-family:'Cinzel',serif;cursor:pointer;border:none;border-radius:7px;padding:13px 28px;font-size:14px;font-weight:600;letter-spacing:2px;text-transform:uppercase;transition:all .2s;position:relative;overflow:hidden}
.btn::after{content:'';position:absolute;inset:0;background:linear-gradient(rgba(255,255,255,.1),transparent);pointer-events:none}
.btn:hover{transform:translateY(-2px)}
.btn:active{transform:translateY(0) scale(.98)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none}
.btn-gold{background:linear-gradient(135deg,#e8c97a 0%,#c9a84c 50%,#8b6914 100%);color:#1a0f05;box-shadow:0 4px 20px rgba(201,168,76,.45),inset 0 1px 0 rgba(255,255,255,.2)}
.btn-gold:hover{box-shadow:0 6px 28px rgba(201,168,76,.7)}
.btn-stone{background:linear-gradient(135deg,var(--stone-l),var(--stone));color:var(--parch);box-shadow:0 4px 12px rgba(0,0,0,.4)}
.btn-blood{background:linear-gradient(135deg,var(--blood-l),var(--blood));color:var(--parch);box-shadow:0 4px 12px rgba(139,26,26,.5)}

/* ── PANELS ── */
.panel{background:linear-gradient(160deg,var(--parch) 0%,var(--parch-d) 100%);border-radius:12px;padding:22px 26px;box-shadow:0 8px 36px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.45);border:1px solid var(--gold-d)}
.panel-dark{background:rgba(22,12,4,.88);border:1px solid rgba(201,168,76,.22);border-radius:12px;padding:20px 24px;backdrop-filter:blur(6px)}

/* ── HUD ── */
#hud{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px}
@media(min-width:580px){#hud{grid-template-columns:repeat(4,1fr)}}
.stat-box{background:rgba(22,12,4,.88);border:1px solid rgba(201,168,76,.28);border-radius:10px;padding:10px 12px;text-align:center;transition:border-color .3s}
.stat-box.pulse-bad{animation:pulseBad .6s}
.stat-box.pulse-good{animation:pulseGood .6s}
@keyframes pulseBad{0%,100%{border-color:rgba(201,168,76,.28)}50%{border-color:#c0392b;box-shadow:0 0 12px rgba(192,57,43,.5)}}
@keyframes pulseGood{0%,100%{border-color:rgba(201,168,76,.28)}50%{border-color:#4a8c42;box-shadow:0 0 12px rgba(74,140,66,.5)}}
.s-icon{font-size:15px;margin-bottom:2px}
.s-label{font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.75}
.s-value{font-family:'Cinzel',serif;font-size:22px;font-weight:700;color:var(--parch);line-height:1.2}
.s-bar{height:4px;border-radius:2px;background:rgba(255,255,255,.08);margin-top:4px;overflow:hidden}
.s-bar-fill{height:100%;border-radius:2px;transition:width .6s cubic-bezier(.4,0,.2,1)}

/* ── WAYPOINT TRACK ── */
.prog-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:7px}
.prog-track{background:rgba(22,12,4,.88);border:1px solid rgba(201,168,76,.22);border-radius:22px;padding:10px 16px;display:flex;align-items:center;gap:4px;overflow-x:auto;margin-bottom:16px;scrollbar-width:thin}
.wp{display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0}
.wp-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;border:2px solid rgba(201,168,76,.25);background:rgba(22,12,4,.7);transition:all .4s}
.wp-dot.done{background:var(--gold-d);border-color:var(--gold);filter:drop-shadow(0 0 4px rgba(201,168,76,.4))}
.wp-dot.cur{background:linear-gradient(135deg,var(--gold-l),var(--gold));border-color:var(--gold-l);box-shadow:0 0 16px rgba(201,168,76,.7);animation:wpPulse 2s ease-in-out infinite}
@keyframes wpPulse{0%,100%{box-shadow:0 0 10px rgba(201,168,76,.5)}50%{box-shadow:0 0 22px rgba(201,168,76,.9)}}
.wp-name{font-family:'Cinzel',serif;font-size:7px;color:var(--gold);opacity:.65;letter-spacing:.5px;white-space:nowrap;max-width:48px;text-align:center}
.wp-line{flex:1;height:2px;background:rgba(201,168,76,.15);min-width:10px;transition:background .4s}
.wp-line.done{background:var(--gold-d)}

/* ═══ ANIMATION STAGE (enhanced) ═══ */
#anim-stage{height:130px;margin-bottom:14px;border-radius:14px;overflow:hidden;position:relative;border:1px solid rgba(201,168,76,.2)}
.stage-bg{position:absolute;inset:0;transition:background 0.6s ease}
.stage-overlay{position:absolute;inset:0;pointer-events:none}
.stage-particles{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.particle{position:absolute;pointer-events:none}

/* Animated scene elements */
.scene-el{position:absolute;z-index:2;pointer-events:none}

/* Mountains scene */
.mountain{position:absolute;bottom:0;width:0;height:0;border-style:solid}

/* City silhouette */
.city-block{position:absolute;bottom:0;background:rgba(0,0,0,.4)}

/* Sun/Moon */
.stage-sun{position:absolute;border-radius:50%;animation:sunGlow 3s ease-in-out infinite}
@keyframes sunGlow{0%,100%{filter:drop-shadow(0 0 8px currentColor)}50%{filter:drop-shadow(0 0 20px currentColor)}}

/* Caravan marcher */
.marcher{position:absolute;font-size:22px;animation:march 4s linear infinite}
@keyframes march{0%{left:-5%;transform:scaleX(1)}50%{left:50%}100%{left:105%;transform:scaleX(1)}}

/* Lightning */
.lightning{position:absolute;color:#fff;font-size:40px;animation:bolt 2.5s ease-in-out infinite;opacity:0}
@keyframes bolt{0%,100%{opacity:0}10%,12%{opacity:1}11%,13%{opacity:0}20%,22%{opacity:.8}21%,23%{opacity:0}}

/* Spinning merchant */
.spin-mer{animation:spinIn 1s cubic-bezier(.34,1.56,.64,1) both}
@keyframes spinIn{from{transform:scale(0) rotate(-30deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}

.stage-icon-big{font-size:62px;position:absolute;top:50%;left:50%;transform:translate(-50%,-60%);z-index:4;animation:stagePop .5s cubic-bezier(.34,1.56,.64,1) both}
@keyframes stagePop{from{transform:translate(-50%,-40%) scale(0) rotate(-20deg);opacity:0}to{transform:translate(-50%,-60%) scale(1) rotate(0);opacity:1}}
.stage-label{position:absolute;bottom:10px;right:14px;font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;color:rgba(244,232,193,.6);z-index:5}
.stage-day{position:absolute;top:10px;left:14px;font-family:'Cinzel',serif;font-size:11px;letter-spacing:1px;color:rgba(244,232,193,.5);z-index:5}

/* region badge */
.region-badge{position:absolute;top:10px;right:14px;font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.7);background:rgba(0,0,0,.4);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:2px 8px;z-index:5}

/* ── NARRATIVE ── */
#narrative-card{margin-bottom:14px}
.ev-hdr{display:flex;align-items:flex-start;gap:12px;margin-bottom:12px}
.ev-title-wrap{flex:1}
.ev-tag{font-family:'Cinzel',serif;font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:3px 9px;border-radius:20px;display:inline-block;margin-bottom:5px}
.tag-battle{background:rgba(139,26,26,.2);color:#e57373;border:1px solid rgba(139,26,26,.35)}
.tag-disease{background:rgba(120,70,20,.2);color:#c4956a;border:1px solid rgba(120,70,20,.35)}
.tag-weather{background:rgba(44,83,100,.25);color:#7ab8d4;border:1px solid rgba(44,83,100,.4)}
.tag-political{background:rgba(107,47,160,.2);color:#c07cc0;border:1px solid rgba(107,47,160,.35)}
.tag-travel{background:rgba(45,90,39,.2);color:#80c878;border:1px solid rgba(45,90,39,.35)}
.tag-market{background:rgba(201,168,76,.15);color:var(--gold-l);border:1px solid rgba(201,168,76,.3)}
.tag-cultural{background:rgba(50,80,120,.2);color:#7ab0e0;border:1px solid rgba(50,80,120,.35)}
.ev-title{font-family:'Cinzel',serif;font-size:18px;font-weight:700;color:var(--ink);line-height:1.2}
.ev-text{font-size:16px;line-height:1.8;color:#2c1810;font-style:italic}
.skill-bonus{display:inline-flex;align-items:center;gap:5px;background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.3);border-radius:20px;padding:4px 10px;font-family:'Cinzel',serif;font-size:10px;color:var(--gold);margin-top:8px;letter-spacing:.5px}

/* ── CHOICES ── */
.ch-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.65;margin-bottom:8px}
.ch-btn{width:100%;text-align:left;padding:13px 16px;background:rgba(244,232,193,.05);border:1px solid rgba(201,168,76,.18);border-radius:9px;color:var(--parch);font-family:'Crimson Text',serif;font-size:15px;line-height:1.5;cursor:pointer;margin-bottom:8px;transition:all .2s;display:flex;align-items:flex-start;gap:10px}
.ch-btn:hover{background:rgba(201,168,76,.1);border-color:rgba(201,168,76,.45);transform:translateX(5px)}
.ch-btn.boosted{border-color:rgba(201,168,76,.5);background:rgba(201,168,76,.08)}
.ch-btn.boosted .ch-letter{color:var(--gold-l)}
.ch-letter{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:var(--gold);min-width:22px;padding-top:1px;flex-shrink:0}
.ch-cost{font-size:12px;color:rgba(201,168,76,.55);margin-top:3px;font-style:italic}
.ch-boost{font-size:11px;color:#80c878;margin-top:2px}

/* ── OUTCOME ── */
#outcome-sec{display:none;margin-bottom:14px}
.out-good{border-left:4px solid var(--grn-l)}
.out-bad{border-left:4px solid var(--blood-l)}
.out-neutral{border-left:4px solid var(--gold-d)}
.out-text{font-size:16px;line-height:1.75;color:var(--ink)}
.out-effects{margin-top:10px;display:flex;flex-wrap:wrap;gap:8px}
.eff{font-family:'Cinzel',serif;font-size:11px;font-weight:600;padding:4px 11px;border-radius:20px}
.eff-good{background:rgba(45,90,39,.12);color:var(--grn-l);border:1px solid rgba(45,90,39,.28)}
.eff-bad{background:rgba(139,26,26,.12);color:#e57373;border:1px solid rgba(139,26,26,.28)}

/* ── PARTY ── */
#party-display{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.party-member{background:rgba(22,12,4,.7);border:1px solid rgba(201,168,76,.2);border-radius:8px;padding:8px 12px;display:flex;align-items:center;gap:8px;flex:1;min-width:140px}
.party-member.dead{opacity:.4;border-style:dashed}
.pm-avatar{font-size:22px}
.pm-name{font-family:'Cinzel',serif;font-size:12px;color:var(--parch);font-weight:600}
.pm-skills{display:flex;gap:4px;flex-wrap:wrap;margin-top:2px}
.pm-skill{font-size:11px;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.2);border-radius:10px;padding:1px 6px;color:var(--gold);font-family:'Cinzel',serif;letter-spacing:.5px}

/* ── LOG ── */
#log-toggle{display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none}
#log-toggle span{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);opacity:.65}
#log-body{display:none;max-height:150px;overflow-y:auto;margin-top:10px}
.log-e{padding:5px 0;border-bottom:1px solid rgba(201,168,76,.08);font-size:13px;color:rgba(244,232,193,.55);line-height:1.4}
.log-e.milestone{color:rgba(201,168,76,.7)}
.log-day{font-family:'Cinzel',serif;font-size:10px;color:var(--gold);opacity:.7}

/* ── END SCREENS ── */
#screen-go,#screen-win{display:none;text-align:center;padding:40px 20px}
.end-icon{font-size:88px;margin-bottom:18px;filter:drop-shadow(0 0 20px rgba(201,168,76,.4))}
.end-title{font-family:'Cinzel',serif;font-size:clamp(28px,6vw,42px);font-weight:900;margin-bottom:12px}
.end-sub{font-size:17px;line-height:1.75;max-width:520px;margin:0 auto 24px;font-style:italic;color:var(--parch);opacity:.85}
#screen-go .end-title{color:var(--blood-l);text-shadow:0 0 20px rgba(192,57,43,.5)}
#screen-win .end-title{color:var(--gold);text-shadow:0 0 20px rgba(201,168,76,.6)}

/* ── SCORE SCREEN ── */
.score-section{background:rgba(22,12,4,.7);border:1px solid rgba(201,168,76,.25);border-radius:12px;padding:24px;margin:16px 0;max-width:520px;margin-left:auto;margin-right:auto}
.score-big{font-family:'Cinzel',serif;font-size:52px;font-weight:900;color:var(--gold);line-height:1}
.score-lbl{font-size:13px;color:var(--gold);opacity:.6;letter-spacing:3px;text-transform:uppercase;margin-bottom:4px}
.rating-badge{display:inline-block;font-family:'Cinzel',serif;font-size:22px;font-weight:900;padding:10px 28px;border-radius:8px;margin:14px 0;letter-spacing:2px}
.rating-legendary{background:linear-gradient(135deg,#e8c97a,#c9a84c);color:#1a0f05;box-shadow:0 0 30px rgba(201,168,76,.6)}
.rating-heroic{background:linear-gradient(135deg,#c0d8ff,#7ab8d4);color:#0d1e2a;box-shadow:0 0 20px rgba(122,184,212,.4)}
.rating-merchant{background:linear-gradient(135deg,#c8e6c9,#4a8c42);color:#0a1f09;box-shadow:0 0 16px rgba(74,140,66,.4)}
.rating-traveler{background:linear-gradient(135deg,#ffe0b2,#c9a84c);color:#2c1810}
.rating-survivor{background:linear-gradient(135deg,#5c4a32,#2c1810);color:#e0cc94;border:1px solid rgba(201,168,76,.3)}
.score-breakdown{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px;text-align:left}
.sb-row{padding:8px 12px;background:rgba(244,232,193,.04);border-radius:6px;border:1px solid rgba(201,168,76,.1)}
.sb-cat{font-family:'Cinzel',serif;font-size:10px;color:var(--gold);opacity:.7;letter-spacing:1px}
.sb-val{font-family:'Cinzel',serif;font-size:16px;color:var(--parch);font-weight:700}
.sb-row.full{grid-column:1/-1}
.cargo-manifest{margin-top:18px;text-align:left;border-top:1px solid rgba(201,168,76,.2);padding-top:14px}
.cargo-title{font-family:'Cinzel',serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:10px}
.cargo-item{display:flex;align-items:center;gap:8px;padding:6px 10px;background:rgba(244,232,193,.04);border-radius:6px;margin-bottom:5px;border:1px solid rgba(201,168,76,.08)}
.cargo-item-icon{font-size:20px}
.cargo-item-info{flex:1}
.cargo-item-name{font-family:'Cinzel',serif;font-size:12px;color:var(--parch)}
.cargo-item-val{font-size:11px;color:var(--gold);opacity:.7}
.cargo-bar{height:3px;border-radius:2px;background:rgba(201,168,76,.15);margin-top:3px}
.cargo-bar-fill{height:100%;border-radius:2px;background:var(--gold)}

